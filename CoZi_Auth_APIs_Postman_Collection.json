            }
          },
          "status": "OK",
          "code": 200,
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
          ],
          "body": "{\n  \"token\": \"eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJ1c2VyQGV4YW1wbGUuY29tIiwicm9sZXMiOlsiQ1VTVE9NRVIiXSwiaWF0IjoxNjE2NDM2NDAwLCJleHAiOjE2MTY1MjI4MDB9.signature\",\n  \"tokenType\": \"Bearer\",\n  \"roles\": [\"CUSTOMER\"],\n  \"userId\": 1\n}"
